<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ── Storage permissions ─────────────────────────────────────────── -->
    <!-- Android 9 and below: broad storage access -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />

    <!-- Android 10 (Q): scoped storage, but legacy flag lets us scan -->
    <!-- Android 13+: granular media permissions -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />

    <!-- Manage ALL files — used on Android 11+ to scan non-media files.
         Declared here so the user can grant it from Settings. The app
         handles graceful degradation if not granted. -->
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage"
        xmlns:tools="http://schemas.android.com/tools" />

    <!-- Needed to query the Recycle Bin (trashed MediaStore entries) on Android 11+ -->
    <uses-permission android:name="android.permission.ACCESS_MEDIA_LOCATION" />

    <!-- WakeLock keeps the CPU alive during a full scan -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Notifications for scan-complete alerts (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Foreground service for deep/full scans -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".FileSalvageApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FileSalvage"
        android:requestLegacyExternalStorage="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FileSalvage.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Foreground service for long scans -->
        <service
            android:name=".services.ScanForegroundService"
            android:foregroundServiceType="dataSync"
            android:exported="false" />

    </application>

</manifest>
