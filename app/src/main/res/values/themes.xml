<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.FileSalvage" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <style name="Theme.FileSalvage.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0F1A</item>
        <item name="windowSplashScreenAnimatedIcon">@android:drawable/ic_menu_search</item>
        <item name="postSplashScreenTheme">@style/Theme.FileSalvage</item>
    </style>
</resources>
